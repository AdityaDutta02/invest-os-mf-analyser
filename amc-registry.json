{
  "_meta": {
    "purpose": "Ingestion registry for Indian MF monthly portfolio disclosures (SEBI-mandated holdings spreadsheets with ISIN + % to NAV). Source of holdings data for the analyser.",
    "as_of": "2026-06-17",
    "scheme_master_and_nav": {
      "source": "mfapi.in",
      "base": "https://api.mfapi.in",
      "endpoints": [
        "/mf",
        "/mf/search?q=",
        "/mf/{scheme_code}",
        "/mf/{scheme_code}/latest",
        "/mf/latest"
      ],
      "auth": "none",
      "provides": "scheme list, AMFI codes, ISIN, plan/option, full NAV history (AMFI-sourced)",
      "does_not_provide": "holdings / portfolio (use AMC XLS below)"
    },
    "packaging_types": [
      "single_workbook (all schemes)",
      "per_scheme (one file/scheme)",
      "zip (archive of per-scheme files)"
    ],
    "fetch_methods": [
      "direct (plain server fetch OK)",
      "needs_js (headless browser to discover/download)",
      "needs_form (select year/month then download)"
    ],
    "key_findings": [
      "~70% of AMC portals are JS-rendered and/or bot-gated (Akamai/Cloudflare/Radware) — plain fetch returns 403/empty. Ingestion needs a headless-browser discovery+download step.",
      "Most file URLs carry random CMS/CDN hashes (Strapi /uploads/, Sitecore /-/media/, ?sfvrsn tokens) — NOT constructable. Scrape each month's link from the rendered page using a match rule; do not template URLs.",
      "Backfill depth is deep for legacy AMCs (ABSL ~2009, Shriram ~2008, Nippon 2013, Quantum 2011, Canara 2017, HSBC 2018) and shallow (since-launch) for new AMCs."
    ],
    "status_counts": {
      "verified": 30,
      "pending": 20,
      "total_amcs": 50
    }
  },
